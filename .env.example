# WhitePaper XBRL Environment Variables
# Copy this file to .env.local for local development

# Optional: GLEIF API for LEI validation
# The GLEIF API is public and doesn't require authentication for basic lookups
# GLEIF_API_URL=https://api.gleif.org/api/v1

# Optional: Upstash Redis for distributed rate limiting (Vercel deployment)
# Get credentials from https://console.upstash.com
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# Optional: Legacy Redis URL (not used by Upstash integration)
# REDIS_URL=redis://localhost:6379

# Authentication (NextAuth v5)
# Required for production. Generate secret: npx auth secret
# AUTH_SECRET=your-random-secret-here

# GitHub OAuth (optional — enable GitHub sign-in)
# Create app: https://github.com/settings/developers
# AUTH_GITHUB_ID=your-github-client-id
# AUTH_GITHUB_SECRET=your-github-client-secret

# Google OAuth (optional — enable Google sign-in)
# Create credentials: https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret

# Node environment
NODE_ENV=development
